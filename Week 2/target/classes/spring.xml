<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans 
        http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="emailService" class="com.cognizant.EmailService">
        <property name="message" value="Dependency Injection in Spring!"/>
    </bean>

    <bean id="messageProcessor" class="com.cognizant.MessageProcessor">
        <property name="messageService" ref="emailService"/>
    </bean>
</beans>
